# ── Mission Control API ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://YOUR_VPS_IP:3000

# ── Intake form (dedicated server on port 3001) ────────────────────────
VPS_INTAKE_URL=http://YOUR_VPS_IP:3001/api/intake

# Shared secret between Vercel and VPS (pick any long random string)
# Set this BOTH here AND as an env var on the VPS
INTAKE_SECRET=your-long-random-secret-here

# ── VPS env vars (set in PM2 ecosystem or ~/.bashrc) ──────────────────
# INTAKE_SECRET=same-string-as-above
# VPS_SERVER_URL=http://127.0.0.1:3001   ← used by baileys-server.js for photo uploads
# SITE_BASE_URL=https://webuilder-liart.vercel.app

# ── Port map ───────────────────────────────────────────────────────────
# 3000 → server/index.js        (Mission Control dashboard API)
# 3001 → server/intake-server.js (intake form + photo uploads)  ← NEW
# 3002 → simple-jj/server.js    (JJ sales agent)
# 3003 → baileys-server.js      (WhatsApp)
