# ── Lemon Squeezy ─────────────────────────────────────────────────────────────
# Get all values from: https://app.lemonsqueezy.com

# API key (Settings → API → Create new key)
LEMON_SQUEEZY_API_KEY=

# Webhook signing secret (Settings → Webhooks → Create webhook → copy secret)
# Webhook URL to register: https://webuilder-liart.vercel.app/api/ls/webhook
# Events to subscribe: order_created
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Store ID: Settings → Stores → click your store → copy numeric ID from URL
LEMON_SQUEEZY_STORE_ID=

# Variant ID: Products → click your product → click the variant → copy numeric ID from URL
LEMON_SQUEEZY_VARIANT_ID=

# ── VPS API ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://204.168.207.116:3000
